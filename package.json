{
    "name": "all-mangas-reader",
    "version": "0.6.0",
    "private": true,
    "description": "A lightweight cross-browser manga reader extension",
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*",
        "tooling/*"
    ],
    "engines": {
        "node": ">=22.0.0",
        "npm": ">=11.0.0"
    },
    "scripts": {
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "dev": "npm run dev --workspace @amr/extension",
        "dev:firefox": "npm run dev:firefox --workspace @amr/extension",
        "build": "npm run build --workspace @amr/extension",
        "build:firefox": "npm run build:firefox --workspace @amr/extension",
        "zip": "npm run zip --workspace @amr/extension",
        "zip:firefox": "npm run zip:firefox --workspace @amr/extension",
        "typecheck": "npm run typecheck --workspaces --if-present",
        "lint": "eslint .",
        "test": "npm run test --workspaces --if-present",
        "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=json-summary --coverage.reporter=lcov --passWithNoTests",
        "check": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm run build:firefox && npm run test"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.8",
        "vitest": "^4.1.8",
        "eslint": "^9.39.4",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.4.1",
        "typescript-eslint": "^8.61.1"
    },
    "packageManager": "npm@11.6.2"
}
