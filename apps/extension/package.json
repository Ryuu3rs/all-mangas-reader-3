{
    "name": "@amr/extension",
    "version": "0.8.3",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "typecheck": "wxt prepare && svelte-check --tsconfig ./tsconfig.json",
        "test": "vitest run",
        "postinstall": "wxt prepare"
    },
    "dependencies": {
        "@amr/contracts": "*",
        "@amr/source-sdk": "*",
        "@amr/sources": "*",
        "dexie": "^4.4.3",
        "svelte": "^5.56.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@wxt-dev/module-svelte": "^2.0.5",
        "fake-indexeddb": "^6.2.5",
        "svelte-check": "^4.6.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8",
        "wxt": "^0.20.26"
    }
}
