# Community stats API — copy to .env and fill in real values (never commit .env)
# API base URL for fetch calls in community.ts
VITE_COMMUNITY_API_URL=https://your-api-domain.example.com/api

# Wildcard origin for host_permissions in the manifest
VITE_COMMUNITY_API_ORIGIN=https://your-api-domain.example.com/*

# Firefox add-on signing (AMO) — get from https://addons.mozilla.org/developers/addon/api/key/
AMO_JWT_ISSUER=user:XXXXXXX:XXX
AMO_JWT_SECRET=your-amo-jwt-secret-here
